# ============================================
# xSwift Bot — Environment Variables
# Copy this file to .env for local development
# ============================================

# Discord
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=1501185434150109214
GUILD_ID=your_test_guild_id_for_dev

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/xswift?retryWrites=true&w=majority

# Twitter/X API v2
TWITTER_BEARER_TOKEN=your_bearer_token_here
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Bot Config
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
BOT_PREFIX=x!

# Feed Settings
POLL_INTERVAL_MS=60000
MAX_FEEDS_PER_GUILD=10
MAX_FEEDS_FREE=3
MAX_FEEDS_PREMIUM=25

# Links
SUPPORT_SERVER_URL=https://discord.gg/yourserver
INVITE_URL=https://discord.com/oauth2/authorize?client_id=1501185434150109214&permissions=537226304&scope=bot%20applications.commands
DASHBOARD_URL=https://xswift.up.railway.app
