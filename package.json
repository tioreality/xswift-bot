{
    "name": "xswift",
    "version": "1.0.0",
    "description": "xSwift — The all-in-one Discord bot for Twitter/X, Bluesky and more",
    "main": "dist/index.js",
    "scripts": {
          "build": "tsc",
          "start": "node dist/index.js",
          "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
          "deploy": "tsc && node dist/index.js",
          "deploy-commands": "ts-node deploy-commands.ts",
          "lint": "eslint src --ext .ts",
          "typecheck": "tsc --noEmit"
    },
    "dependencies": {
          "discord.js": "^14.14.1",
          "@discordjs/rest": "^2.3.0",
          "discord-api-types": "^0.37.83",
          "mongoose": "^8.2.1",
          "twitter-api-v2": "^1.17.0",
          "express": "^4.18.3",
          "winston": "^3.12.0",
          "node-cron": "^3.0.3",
          "dotenv": "^16.4.5",
          "axios": "^1.6.8"
    },
    "devDependencies": {
          "@types/node": "^20.11.30",
          "@types/express": "^4.17.21",
          "@types/node-cron": "^3.0.11",
          "typescript": "^5.4.3",
          "ts-node": "^10.9.2",
          "ts-node-dev": "^2.0.0",
          "@typescript-eslint/eslint-plugin": "^7.3.1",
          "@typescript-eslint/parser": "^7.3.1",
          "eslint": "^8.57.0"
    },
    "engines": {
          "node": ">=20.0.0"
    }
}
